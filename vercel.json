{
  "functions": {
    "api/book-profile.js":       { "maxDuration": 30 },
    "api/claude-enrich.js":      { "maxDuration": 30 },
    "api/book-search-enrich.js": { "maxDuration": 30 },
    "api/cover.js":              { "maxDuration": 20 },
    "api/telegram-search.js":   { "maxDuration": 30 },
    "api/telegram-download.js": { "maxDuration": 30 },
    "api/send-to-kindle.js":    { "maxDuration": 30 }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options",  "value": "nosniff" },
        { "key": "X-Frame-Options",          "value": "SAMEORIGIN" },
        { "key": "Referrer-Policy",          "value": "strict-origin-when-cross-origin" },
        { "key": "Strict-Transport-Security","value": "max-age=63072000; includeSubDomains; preload" }
      ]
    }
  ]
}
